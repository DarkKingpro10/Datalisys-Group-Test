// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas = ["dwh"]
}

// NOTE: The datasource expects an environment variable `DATABASE_URL_DWH`
// that points to your Postgres instance and sets the search_path (schema) to the DWH
// Example: postgres://user:pass@host:5432/dbname?schema=gold

// Minimal star-schema models for the `dwh` layer. Models are mapped explicitly
// to the `dwh` schema tables using @@map("dwh.<table>") so Prisma queries
// target only the DWH tables.

model DimDate {
  date       DateTime @id
  year       Int?
  month      Int?
  day        Int?
  week       Int?
  quarter    Int?
  is_weekend Boolean?

  FactSales  FactSales[]
  @@schema("dwh")
  @@map("dim_date")
}

model DimCustomer {
  customer_id        String  @id
  customer_unique_id String?
  customer_city      String?
  customer_state     String?

  FactSales          FactSales[]
  @@schema("dwh")
  @@map("dim_customer")
}

model DimProduct {
  product_id            String @id
  product_category_name String?

  FactSales             FactSales[]
  @@schema("dwh")
  @@map("dim_product")
}

model DimOrder {
  order_id                      String  @id
  customer_id                   String?
  order_status                  String?
  order_purchase_timestamp      DateTime?
  order_approved_at             DateTime?
  order_delivered_customer_date DateTime?
  order_estimated_delivery_date DateTime?

  FactSales                     FactSales[]
  @@schema("dwh")
  @@map("dim_order")
}

model FactSales {
  order_id     String
  order_item_id Int
  purchase_date DateTime?
  product_id    String?
  customer_id   String?
  seller_id     String?

  item_price    Decimal? @db.Decimal(10,2)
  freight_value Decimal? @db.Decimal(10,2)
  payment_value_allocated Decimal? @db.Decimal(10,2)
  is_delivered  Boolean?
  is_canceled   Boolean?
  is_on_time    Boolean?

  @@id([order_id, order_item_id])
  @@index([purchase_date])
  @@index([customer_id])
  @@index([product_id])

  // Relations to dwh dims
  DimDate     DimDate?     @relation(fields: [purchase_date], references: [date])
  DimCustomer DimCustomer? @relation(fields: [customer_id], references: [customer_id])
  DimProduct  DimProduct?  @relation(fields: [product_id], references: [product_id])
  DimOrder    DimOrder?    @relation(fields: [order_id], references: [order_id])

  @@schema("dwh")
  @@map("fact_sales")
}

model DimOrderStatus {
  id           String  @id @default(uuid()) @db.Uuid
  code         String  @unique
  display_name String?

  @@schema("dwh")
  @@map("dim_order_status")
}

model DimCustomerState {
  id   String @id @default(uuid()) @db.Uuid
  code String @unique

  @@schema("dwh")
  @@map("dim_customer_state")
}

model DimProductCategory {
  id           String @id @default(uuid()) @db.Uuid
  code         String @unique
  display_name String?

  @@schema("dwh")
  @@map("dim_product_category")
}